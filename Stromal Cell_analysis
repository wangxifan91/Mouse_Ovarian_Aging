Y_ISC_DEG <- Y_ISC[Y_ISC$p_val_adj < 0.05, ]
M_ISC_DEG <- M_ISC[M_ISC$p_val_adj < 0.05, ]
O_ISC_DEG <- O_ISC[O_ISC$p_val_adj < 0.05, ]
all_ISC_DEG <-unique(c(rownames(Y_ISC_DEG),rownames(M_ISC_DEG),rownames(O_ISC_DEG)))

ISC_matrix=readRDS("~/SCTC_subset_analysis/expr_data_ISC.rds")
ISC <- ISC_matrix[all_ISC_DEG, ]

a=sum(grepl("Y_r", colnames(ISC)))
b=sum(grepl("M_r", colnames(ISC)))
c=sum(grepl("M_ir", colnames(ISC)))
d=sum(grepl("O_a", colnames(ISC)))
group = c(rep(4.5, a), rep(10.5, b),rep(10.5,c), rep(16, d))

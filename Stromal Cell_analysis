  if(i %% n2 == 0) paste0(i,'/',n,' ', round(i/n,2)*100,'% done\n') %>% cat
  # Calculate LOESS estimate
  y_row = data.frame(age=group, expression=ISC_z[i,] %>% unlist)
  estimates = predict(loess(expression ~ age, data=y_row, span=0.75))
  estimates %>% data.frame %>% t %>% data.frame
})

